{
  "name": "coursera-tracker",
  "version": "0.1.0",
  "description": "Import Coursera courses and track them inside Obsidian.",
  "main": "main.js",
  "scripts": {
    "build": "rm -rf dist && esbuild src/main.ts --bundle --platform=node --target=es2020 --external:obsidian --loader:.wasm=binary --outdir=dist",
    "build:scrape": "esbuild scripts/scrape.ts --bundle --platform=node --target=es2020 --loader:.wasm=binary --outfile=dist/scrape.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.19.0",
    "typescript": "^4.9.5",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "obsidian": "*"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.2.0"
  },
  "license": "MIT",
  "author": "matzalazar"
}
